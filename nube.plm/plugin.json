{
  "id": "nube.plm",
  "vendor": "nube",
  "name": "plm",
  "displayName": "Product Lifecycle Management",
  "version": "1.0.0",
  "description": "Product management system",
  "category": "manufacturing",
  "nodeTypes": [
    "plm.service",
    "plm.products",
    "plm.product"
  ],
  "_futureNodeTypes": [
    "plm.production-runs",
    "plm.production-run",
    "plm.serialized-units",
    "plm.serialized-unit",
    "plm.work-items",
    "plm.work-item",
    "plm.sites",
    "plm.site"
  ],
  "policy": {
    "nodeTypes": [
      "plm.service",
      "plm.products",
      "plm.product"
    ],
    "_comment": "Add other node types here when implementing additional collections",
    "hooks": {
      "enabled": true,
      "endpoint": "/hooks/nodes",
      "create": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "update": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "delete": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      }
    }
  },
  "widgets": [
    {
      "id": "product-table-widget",
      "displayName": "Product Table",
      "description": "Display products in a table",
      "moduleId": "./ProductTableWidget",
      "category": "Manufacturing",
      "icon": "Package",
      "supportsQuery": false,
      "requiresBackend": false,
      "defaultSize": { "w": 6, "h": 4 },
      "settingsSchemaFile": "product-table-widget-settings.yaml"
    }
  ],
  "execPath": "./nube.plm",
  "args": []
}
