{
  "id": "nube.plm",
  "vendor": "nube",
  "name": "plm",
  "displayName": "Project Lifecycle Management",
  "version": "1.0.0",
  "description": "Project management system",
  "category": "manufacturing",
  "nodeTypes": [
    "plm.service",
    "plm.project",
    "plm.projects",
    "plm.task",
    "plm.ticket",
    "plm.manufacturing-run"
  ],
  "coreNodeTypes": [
    "core.asset",
    "core.component",
    "core.document",
    "core.entry",
    "core.project",
    "core.service",
    "core.task",
    "core.ticket"
  ],
  "_futureNodeTypes": [
    "plm.production-runs",
    "plm.production-run",
    "plm.serialized-units",
    "plm.serialized-unit",
    "plm.work-items",
    "plm.work-item",
    "plm.sites",
    "plm.site"
  ],
  "policy": {
    "nodeTypes": [
      "plm.service",
      "plm.project",
      "plm.projects",
      "plm.task",
      "plm.ticket",
      "plm.manufacturing-run"
    ],
    "_comment": "Add other node types here when implementing additional collections",
    "hooks": {
      "enabled": true,
      "endpoint": "/hooks/nodes",
      "create": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "update": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "delete": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      }
    }
  },
  "widgets": [
    {
      "id": "project-table-widget",
      "displayName": "Project Table",
      "description": "Display projects in a table",
      "moduleId": "./ProjectTableWidget",
      "category": "Manufacturing",
      "icon": "Package",
      "supportsQuery": false,
      "requiresBackend": false,
      "defaultSize": { "w": 6, "h": 4 },
      "settingsSchemaFile": "project-table-widget-settings.yaml"
    }
  ],
  "nodes": [
    {
      "type": "plm.service",
      "displayName": "PLM Service",
      "description": "Project lifecycle management root service",
      "icon": "factory",
      "color": "#8b5cf6",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "tags-references"],
      "constraints": {
        "maxOneNode": true,
        "allowedParents": ["rubix.plugin"]
      },
      "autoFields": {
        "identity": ["service", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.project",
      "displayName": "Project",
      "description": "PLM-managed project with BOM and releases",
      "icon": "package",
      "color": "#3b82f6",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "history-analytics", "tags-references"],
      "constraints": {
        "allowedParents": ["plm.service", "plm.projects"]
      },
      "autoFields": {
        "identity": ["project", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.projects",
      "displayName": "Projects Collection",
      "description": "Container for project catalog",
      "icon": "package",
      "color": "#3b82f6",
      "category": "manufacturing",
      "visibility": {
        "hideIn": ["wiresheet"]
      },
      "constraints": {
        "maxOneNode": true,
        "allowedParents": ["plm.service"]
      },
      "autoFields": {
        "identity": ["collection", "projects", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.manufacturing-run",
      "displayName": "Manufacturing Run",
      "description": "Production batch for hardware manufacturing",
      "icon": "factory",
      "color": "#f59e0b",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "tags-references"],
      "constraints": {
        "allowedParents": ["plm.project", "core.project"]
      },
      "autoFields": {
        "identity": ["manufacturing", "plm", "run"],
        "pluginId": true
      }
    },
    {
      "type": "plm.task",
      "displayName": "Task",
      "description": "Project development task or work item",
      "icon": "list-checks",
      "color": "#8b5cf6",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "tags-references"],
      "constraints": {
        "allowedParents": ["plm.project"]
      },
      "autoFields": {
        "identity": ["task", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.ticket",
      "displayName": "Ticket",
      "description": "Work item, bug, feature request, or chore",
      "icon": "check-square",
      "color": "#6366f1",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "tags-references"],
      "constraints": {
        "allowedParents": ["plm.project", "plm.task"]
      },
      "autoFields": {
        "identity": ["ticket", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "core.document",
      "profile": "plm-bom",
      "displayName": "BOM Item",
      "description": "Bill of Materials entry",
      "icon": "component",
      "color": "#f59e0b",
      "category": "manufacturing",
      "propertyPanels": ["node-settings", "tags-references"],
      "visibility": {
        "hideIn": ["wiresheet"]
      },
      "constraints": {
        "allowedParents": ["plm.project"]
      },
      "autoFields": {
        "identity": ["document", "bom", "plm"]
      }
    },
    {
      "type": "core.entry",
      "profile": "plm-time-entry",
      "displayName": "Time Entry",
      "description": "Time tracking for tasks and work items",
      "icon": "clock",
      "color": "#10b981",
      "category": "manufacturing",
      "visibility": {
        "hideIn": ["sidebar", "wiresheet"]
      },
      "constraints": {
        "allowedParents": ["core.task", "core.ticket"]
      },
      "autoFields": {
        "identity": ["entry", "timesheet", "plm"]
      }
    },
    {
      "type": "core.asset",
      "profile": "plm-unit",
      "displayName": "Hardware Unit",
      "description": "Physical hardware unit with serial tracking",
      "icon": "cpu",
      "color": "#ef4444",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.manufacturing-run"]
      },
      "autoFields": {
        "identity": ["asset", "unit", "hardware", "plm"]
      }
    }
  ],
  "pages": [
    {
      "pageId": "projects-manager",
      "title": "Project Management",
      "icon": "package",
      "description": "Manage PLM projects",
      "nodeTypes": ["plm.projects"],
      "enabled": true,
      "isDefault": true,
      "order": 10,
      "propertyPanels": ["node-settings", "tags-references"],
      "props": {
        "exposedPath": "./Page",
        "useMountPattern": true
      }
    },
    {
      "pageId": "project-detail",
      "title": "Project Details",
      "icon": "package",
      "description": "View project overview and BOM",
      "nodeTypes": ["plm.project"],
      "enabled": true,
      "isDefault": true,
      "order": 10,
      "propertyPanels": ["node-settings", "history-analytics", "tags-references"],
      "props": {
        "exposedPath": "./ProjectDetail",
        "useMountPattern": true
      }
    },
    {
      "pageId": "project-detail-v2",
      "title": "Project Details V2 (Modern UI)",
      "icon": "package",
      "description": "Modern workspace UI for project management",
      "nodeTypes": ["plm.project"],
      "enabled": true,
      "isDefault": false,
      "order": 10,
      "propertyPanels": ["node-settings", "history-analytics", "tags-references"],
      "props": {
        "exposedPath": "./ProjectDetailV2",
        "useMountPattern": true
      }
    },
    {
      "pageId": "tasks-manager",
      "title": "Task Management",
      "icon": "list-checks",
      "description": "Manage project tasks",
      "nodeTypes": ["plm.project"],
      "enabled": true,
      "isDefault": false,
      "order": 11,
      "props": {
        "exposedPath": "./TasksPage",
        "useMountPattern": true
      }
    },
    {
      "pageId": "task-detail",
      "title": "Task Details",
      "icon": "list-checks",
      "description": "View and manage task details, tickets, and logged time",
      "nodeTypes": ["plm.task"],
      "enabled": true,
      "isDefault": true,
      "order": 12,
      "propertyPanels": ["node-settings", "tags-references"],
      "props": {
        "exposedPath": "./TaskDetail",
        "useMountPattern": true
      }
    },
    {
      "pageId": "proof-shared",
      "title": "✅ PROOF: Shared Component",
      "icon": "check-circle-2",
      "description": "Proves plugin uses EXACT SAME DeleteDialog as host",
      "enabled": true,
      "isDefault": false,
      "order": 11,
      "props": {
        "exposedPath": "./ProofShared",
        "useMountPattern": true
      }
    }
  ],
  "execPath": "./nube.plm",
  "args": []
}
