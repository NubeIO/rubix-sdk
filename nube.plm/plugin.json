{
  "id": "nube.plm",
  "vendor": "nube",
  "name": "plm",
  "displayName": "Product Lifecycle Management",
  "version": "1.0.0",
  "description": "Product management system",
  "category": "manufacturing",
  "nodeTypes": [
    "plm.service",
    "plm.product",
    "plm.products",
    "plm.prototest",
    "plm.manufacturing-unit"
  ],
  "coreNodeTypes": [
    "core.asset",
    "core.component",
    "core.document",
    "core.entry",
    "core.product",
    "core.service",
    "core.task",
    "core.ticket"
  ],
  "_futureNodeTypes": [
    "plm.production-runs",
    "plm.production-run",
    "plm.serialized-units",
    "plm.serialized-unit",
    "plm.work-items",
    "plm.work-item",
    "plm.sites",
    "plm.site"
  ],
  "policy": {
    "nodeTypes": [
      "plm.service",
      "plm.product",
      "plm.products",
      "plm.prototest",
      "plm.manufacturing-unit"
    ],
    "_comment": "Add other node types here when implementing additional collections",
    "hooks": {
      "enabled": true,
      "endpoint": "/hooks/nodes",
      "create": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "update": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      },
      "delete": {
        "enabled": true,
        "beforeHook": true,
        "afterHook": true
      }
    }
  },
  "widgets": [
    {
      "id": "product-table-widget",
      "displayName": "Product Table",
      "description": "Display products in a table",
      "moduleId": "./ProductTableWidget",
      "category": "Manufacturing",
      "icon": "Package",
      "supportsQuery": false,
      "requiresBackend": false,
      "defaultSize": { "w": 6, "h": 4 },
      "settingsSchemaFile": "product-table-widget-settings.yaml"
    }
  ],
  "nodes": [
    {
      "type": "plm.service",
      "displayName": "PLM Service",
      "description": "Product lifecycle management root service",
      "icon": "factory",
      "color": "#8b5cf6",
      "category": "manufacturing",
      "constraints": {
        "maxOneNode": true,
        "allowedParents": ["rubix.device"]
      },
      "autoFields": {
        "identity": ["service", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.product",
      "displayName": "Product",
      "description": "PLM-managed product with BOM and releases",
      "icon": "package",
      "color": "#3b82f6",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.service", "plm.products"]
      },
      "autoFields": {
        "identity": ["product", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.products",
      "displayName": "Products Collection",
      "description": "Container for product catalog",
      "icon": "package",
      "color": "#3b82f6",
      "category": "manufacturing",
      "visibility": {
        "hideIn": ["wiresheet"]
      },
      "constraints": {
        "maxOneNode": true,
        "allowedParents": ["plm.service"]
      },
      "autoFields": {
        "identity": ["collection", "products", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "plm.manufacturing-unit",
      "displayName": "Manufacturing Unit",
      "description": "Serialized hardware unit",
      "icon": "cpu",
      "color": "#ef4444",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.product"]
      },
      "autoFields": {
        "identity": ["asset", "unit", "manufacturing", "plm"],
        "pluginId": true
      }
    },
    {
      "type": "core.document",
      "profile": "plm-bom",
      "displayName": "BOM Item",
      "description": "Bill of Materials entry",
      "icon": "component",
      "color": "#f59e0b",
      "category": "manufacturing",
      "visibility": {
        "hideIn": ["wiresheet"]
      },
      "constraints": {
        "allowedParents": ["plm.product"]
      },
      "autoFields": {
        "identity": ["document", "bom", "plm"]
      }
    },
    {
      "type": "core.task",
      "profile": "plm-task",
      "displayName": "Task",
      "description": "Product development task or work item",
      "icon": "list-checks",
      "color": "#8b5cf6",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.product"]
      },
      "autoFields": {
        "identity": ["task", "plm"]
      }
    },
    {
      "type": "core.entry",
      "profile": "plm-time-entry",
      "displayName": "Time Entry",
      "description": "Time tracking for tasks and work items",
      "icon": "clock",
      "color": "#10b981",
      "category": "manufacturing",
      "visibility": {
        "hideIn": ["sidebar", "wiresheet"]
      },
      "constraints": {
        "allowedParents": ["core.task", "core.ticket"]
      },
      "autoFields": {
        "identity": ["entry", "timesheet", "plm"]
      }
    },
    {
      "type": "core.ticket",
      "profile": "plm-work-item",
      "displayName": "Work Item",
      "description": "Task, bug, or feature request",
      "icon": "check-square",
      "color": "#6366f1",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.product"]
      },
      "autoFields": {
        "identity": ["ticket", "work-item", "plm"]
      }
    },
    {
      "type": "core.asset",
      "profile": "plm-unit",
      "displayName": "Hardware Unit",
      "description": "Physical hardware unit with serial tracking",
      "icon": "cpu",
      "color": "#ef4444",
      "category": "manufacturing",
      "constraints": {
        "allowedParents": ["plm.product", "plm.manufacturing-unit"]
      },
      "autoFields": {
        "identity": ["asset", "unit", "hardware", "plm"]
      }
    }
  ],
  "pages": [
    {
      "pageId": "products-manager",
      "title": "Product Management",
      "icon": "package",
      "description": "Manage PLM products",
      "nodeTypes": ["plm.products"],
      "enabled": true,
      "isDefault": true,
      "order": 10,
      "props": {
        "exposedPath": "./Page",
        "useMountPattern": true
      }
    },
    {
      "pageId": "product-detail",
      "title": "Product Details",
      "icon": "package",
      "description": "View product overview and BOM",
      "nodeTypes": ["plm.product"],
      "enabled": true,
      "isDefault": true,
      "order": 10,
      "props": {
        "exposedPath": "./ProductDetail",
        "useMountPattern": true
      }
    },
    {
      "pageId": "tasks-manager",
      "title": "Task Management",
      "icon": "list-checks",
      "description": "Manage product tasks",
      "nodeTypes": ["plm.product"],
      "enabled": true,
      "isDefault": false,
      "order": 11,
      "props": {
        "exposedPath": "./TasksPage",
        "useMountPattern": true
      }
    },
    {
      "pageId": "proof-shared",
      "title": "✅ PROOF: Shared Component",
      "icon": "check-circle-2",
      "description": "Proves plugin uses EXACT SAME DeleteDialog as host",
      "enabled": true,
      "isDefault": false,
      "order": 11,
      "props": {
        "exposedPath": "./ProofShared",
        "useMountPattern": true
      }
    }
  ],
  "execPath": "./nube.plm",
  "args": []
}
