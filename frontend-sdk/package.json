{
  "name": "@rubix/plugin-ui",
  "version": "1.0.0",
  "description": "Reusable UI components and utilities for Rubix plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./globals.css": "./dist/globals.css",
    "./plugin-client": "./dist/plugin-client.js",
    "./types": "./types/index.ts"
  },
  "scripts": {
    "build": "tsup && cp globals.css dist/globals.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/typography": "^0.5.0-alpha.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0-alpha.25",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "rubix",
    "plugin",
    "ui",
    "components",
    "sdk",
    "tailwind",
    "design-system"
  ],
  "author": "Rubix",
  "license": "MIT"
}
