{
  "name": "@rubix-sdk/frontend",
  "version": "1.0.0",
  "description": "Shared UI components and utilities for Rubix and plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./common": "./dist/common/index.js",
    "./common/ui": "./dist/common/ui/index.js",
    "./common/utils": "./dist/common/utils/index.js",
    "./settings": "./dist/settings/index.js",
    "./globals.css": "./dist/globals.css",
    "./plugin-client": "./dist/plugin-client.js",
    "./ras": "./dist/ras/index.js",
    "./types": "./types/index.ts"
  },
  "scripts": {
    "build": "tsup && cp globals.css dist/globals.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.2.0",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/typography": "^0.5.0-alpha.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0-alpha.25",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "rubix",
    "plugin",
    "ui",
    "components",
    "sdk",
    "tailwind",
    "design-system"
  ],
  "author": "Rubix",
